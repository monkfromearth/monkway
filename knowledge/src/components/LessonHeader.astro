---
/**
 * Lesson page header with number, title, description, and tags.
 */
interface Props {
  lessonNumber: string;
  title: string;
  description: string;
}

const { lessonNumber, title, description } = Astro.props;
---

<header class="mb-12">
    <p class="text-mt-accent font-semibold text-sm mb-2">Lesson {lessonNumber}</p>
    <h1 class="text-3xl font-extrabold tracking-tight mb-3">{title}</h1>
    <p class="text-mt-muted text-lg leading-relaxed">{description}</p>
    <div class="flex gap-3 mt-4 text-xs text-mt-muted">
        <slot />
    </div>
</header>

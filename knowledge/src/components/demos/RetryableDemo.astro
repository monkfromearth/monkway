---
/**
 * RetryableDemo — a row of failure cases. Click one to reveal a verdict badge:
 * green "retry" or red "don't retry", plus a one-line reason. Teaches which
 * failures are worth retrying and which are your own bug.
 */
const cases = [
    { code: '429', retry: true,  reason: 'Rate limited. Wait, then it may succeed.' },
    { code: '500', retry: true,  reason: 'Server hiccup on their side. Likely temporary.' },
    { code: 'timeout', retry: true,  reason: 'No answer in time. The next try might land.' },
    { code: '400', retry: false, reason: 'Bad request. The same body fails the same way.' },
    { code: '401', retry: false, reason: 'Bad key. Retrying will not fix the key.' },
];
---

<div class="mt-demo mw-retryable-demo my-6 bg-white border border-mt-border rounded-2xl p-6">
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-4 text-center">Click a failure to see the verdict</p>

    <div class="flex flex-wrap justify-center gap-2 mb-5">
        {cases.map((c, i) => (
            <button
                data-case={i}
                data-retry={c.retry ? '1' : '0'}
                data-reason={c.reason}
                class="font-mono text-sm font-semibold rounded-lg px-4 py-2 border-2 border-mt-border bg-mt-bg hover:border-mt-accent transition-colors"
            >{c.code}</button>
        ))}
    </div>

    <div data-verdict class="text-center min-h-[3.5rem]">
        <span class="text-sm text-mt-muted">Pick a failure above.</span>
    </div>
</div>

<script>
    import { gsap, REDUCED } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mw-retryable-demo').forEach((root) => {
        const buttons = root.querySelectorAll<HTMLButtonElement>('[data-case]');
        const verdict = root.querySelector<HTMLElement>('[data-verdict]')!;

        function show(btn: HTMLButtonElement) {
            // clear selected styling on all, mark this one
            buttons.forEach((b) => b.classList.remove('border-mt-accent', 'border-mt-green', 'border-mt-rose'));

            const retry = btn.dataset.retry === '1';
            const reason = btn.dataset.reason || '';
            btn.classList.add(retry ? 'border-mt-green' : 'border-mt-rose');

            const badgeClass = retry
                ? 'bg-mt-greenLight text-mt-green'
                : 'bg-mt-roseLight text-mt-rose';
            const badgeText = retry ? 'retry' : "don't retry";

            verdict.innerHTML =
                `<span class="inline-block font-mono text-sm font-semibold rounded-full px-3 py-1 ${badgeClass}">${badgeText}</span>` +
                `<p class="text-sm text-mt-muted mt-2">${reason}</p>`;

            if (!REDUCED) {
                gsap.fromTo(verdict, { opacity: 0, y: 6 }, { opacity: 1, y: 0, duration: 0.25, ease: 'power2.out' });
            }
        }

        buttons.forEach((b) => b.addEventListener('click', () => show(b)));
    });
</script>

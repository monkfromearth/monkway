---
/**
 * FallbackDemo — a request tries a ranked list of providers in order.
 * Click a provider to toggle it "down" (red). Press Send: a token starts at the
 * request box, then tries provider 1; if it is down, it drops to provider 2; and so on,
 * landing on the FIRST provider that is up (green check). If all are down, the result
 * reads "all providers down." This is fallback: the same request, a different door.
 */
const W = 360, H = 240;
const reqX = 50, reqY = 120;        // request box on the left
const nodeX = 250;                  // ranked providers on the right
const nodeYs = [50, 120, 190];      // 1, 2, 3 top to bottom
---

<div class="mt-demo mw-fallback-demo my-6 bg-white border border-mt-border rounded-2xl p-6"
     data-reqx={reqX} data-reqy={reqY} data-nodex={nodeX} data-nodeys={nodeYs.join(',')}>
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-3 text-center">Click a provider to take it down, then send</p>

    <svg viewBox={`0 0 ${W} ${H}`} class="w-full max-w-md mx-auto block" role="img" aria-label="a request falling over down a ranked list of providers">
        <!-- links from the request box to each ranked provider -->
        {nodeYs.map((y, i) => (
            <line data-link={i} x1={reqX + 26} y1={reqY} x2={nodeX - 22} y2={y} stroke="#EFE8E2" stroke-width="3" stroke-linecap="round" />
        ))}

        <!-- the request box -->
        <rect x={reqX - 26} y={reqY - 22} width="52" height="44" rx="7" fill="#FBF4EE" stroke="#C96F5A" stroke-width="3" />
        <text x={reqX} y={reqY + 4} text-anchor="middle" font-size="10" fill="#C96F5A" font-family="monospace" font-weight="600">req</text>

        <!-- ranked provider nodes: rank number on the left of each -->
        {nodeYs.map((y, i) => (
            <g data-node={i} style="cursor:pointer">
                <text x={nodeX - 40} y={y + 4} text-anchor="middle" font-size="11" fill="#7A7068" font-family="monospace" font-weight="600">{i + 1}</text>
                <rect data-box={i} x={nodeX - 22} y={y - 18} width="80" height="36" rx="7" fill="#E8F2EA" stroke="#5C9367" stroke-width="3" />
                <text data-status={i} x={nodeX + 18} y={y + 4} text-anchor="middle" font-size="11" fill="#5C9367" font-family="monospace" font-weight="600">up</text>
            </g>
        ))}

        <!-- the travelling request token (hidden until sent) -->
        <circle data-dot cx={reqX + 26} cy={reqY} r="7" fill="#7B6CB5" opacity="0" />
        <!-- the check that lands on the chosen provider -->
        <text data-check x={nodeX + 18} y={nodeYs[0] + 5} text-anchor="middle" font-size="15" fill="#5C9367" font-weight="700" opacity="0">&#10003;</text>
    </svg>

    <div class="flex items-center justify-center gap-4 mt-4">
        <button data-send class="text-sm font-semibold bg-mt-accent text-white rounded-lg px-4 py-2 hover:bg-mt-accent/90 transition-colors">Send</button>
        <span data-result class="text-sm font-mono text-mt-muted">ready</span>
    </div>
</div>

<script>
    import { gsap, REDUCED } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mw-fallback-demo').forEach((root) => {
        const reqX = Number(root.dataset.reqx), reqY = Number(root.dataset.reqy);
        const nodeX = Number(root.dataset.nodex);
        const nodeYs = (root.dataset.nodeys || '').split(',').map(Number);

        const dot = root.querySelector<SVGCircleElement>('[data-dot]')!;
        const check = root.querySelector<SVGTextElement>('[data-check]')!;
        const result = root.querySelector<HTMLElement>('[data-result]')!;
        const sendBtn = root.querySelector<HTMLButtonElement>('[data-send]')!;

        // state: each provider up or down
        const up = [true, true, true];
        let busy = false;

        function paint() {
            up.forEach((isUp, i) => {
                const box = root.querySelector<SVGRectElement>(`[data-box="${i}"]`)!;
                const status = root.querySelector<SVGTextElement>(`[data-status="${i}"]`)!;
                if (isUp) {
                    box.setAttribute('fill', '#E8F2EA'); box.setAttribute('stroke', '#5C9367');
                    status.textContent = 'up'; status.setAttribute('fill', '#5C9367');
                } else {
                    box.setAttribute('fill', '#F7E9E6'); box.setAttribute('stroke', '#C96F5A');
                    status.textContent = 'down'; status.setAttribute('fill', '#C96F5A');
                }
            });
        }

        // toggle a provider up/down on click
        up.forEach((_, i) => {
            const node = root.querySelector<SVGGElement>(`[data-node="${i}"]`)!;
            node.addEventListener('click', () => { if (!busy) { up[i] = !up[i]; paint(); } });
        });

        const target = () => up.findIndex((u) => u);

        function send() {
            if (busy) return;
            const t = target();
            gsap.set(check, { opacity: 0 });

            if (t === -1) {
                result.textContent = 'all providers down';
                result.setAttribute('class', 'text-sm font-mono text-mt-rose');
                gsap.set(dot, { opacity: 0 });
                return;
            }

            result.textContent = `served by provider ${t + 1}`;
            result.setAttribute('class', 'text-sm font-mono text-mt-green');

            const land = () => {
                gsap.set(dot, { opacity: 0 });
                check.setAttribute('y', String(nodeYs[t] + 5));
                gsap.set(check, { opacity: 1 });
                busy = false;
            };

            if (REDUCED) {
                gsap.set(dot, { attr: { cx: nodeX - 24, cy: nodeYs[t] }, opacity: 0 });
                land();
                return;
            }

            // animate the token tripping down the ranked list: stop at each DOWN provider
            // it tries before landing on the first UP one.
            busy = true;
            gsap.set(dot, { attr: { cx: reqX + 26, cy: reqY }, opacity: 1 });
            const tl = gsap.timeline({ onComplete: land });
            for (let i = 0; i <= t; i++) {
                tl.to(dot, { attr: { cx: nodeX - 24, cy: nodeYs[i] }, duration: 0.4, ease: 'power2.inOut' });
                if (i < t) {
                    // bounced off a down provider: a small recoil before trying the next
                    tl.to(dot, { attr: { cx: nodeX - 40 }, duration: 0.15, ease: 'power1.in' });
                }
            }
        }

        sendBtn.addEventListener('click', send);

        paint();
    });
</script>

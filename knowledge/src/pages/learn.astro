---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const units = [
  {
    n: '0', name: 'The Gate', slug: 'gate',
    blurb: 'What a gateway is, and why one door in front of many models.',
    lessons: [
      { n: '0.1', slug: 'what-a-gateway-is', t: 'What a gateway is' },
      { n: '0.2', slug: 'the-request-journey', t: "A request's journey" },
      { n: '0.3', slug: 'why-a-gateway', t: 'Why a gateway at all' },
    ],
  },
  {
    n: '1', name: 'The Proxy', slug: 'proxy',
    blurb: 'Forwarding a request, and what "the same API" really means.',
    lessons: [
      { n: '1.1', slug: 'what-a-proxy-does', t: 'What a proxy does' },
      { n: '1.2', slug: 'one-api-many-providers', t: 'One API, many providers' },
      { n: '1.3', slug: 'streaming-the-answer', t: 'Streaming the answer' },
    ],
  },
  {
    n: '2', name: 'When It Fails', slug: 'failure',
    blurb: 'Retries, backoff and jitter, timeouts, and idempotency.',
    lessons: [
      { n: '2.1', slug: 'ways-a-call-fails', t: 'Ways a call fails' },
      { n: '2.2', slug: 'idempotency', t: 'Idempotency: safe to retry?' },
      { n: '2.3', slug: 'backoff-and-jitter', t: 'Backoff and jitter' },
      { n: '2.4', slug: 'timeouts-and-deadlines', t: 'Timeouts and deadlines' },
    ],
  },
  {
    n: '3', name: 'Choosing a Path', slug: 'routing',
    blurb: 'Routing policy: cost vs latency vs quality, and fallback.',
    lessons: [
      { n: '3.1', slug: 'routing-policy', t: 'Many providers, one choice' },
      { n: '3.2', slug: 'cost-latency-quality', t: 'Cost, latency, quality' },
      { n: '3.3', slug: 'fallback', t: 'Fallback when a door is closed' },
    ],
  },
  {
    n: '4', name: 'Remembering Answers', slug: 'cache',
    blurb: 'Exact vs semantic caching, embeddings, nearest-neighbor lookup.',
    lessons: [
      { n: '4.1', slug: 'exact-match-cache', t: 'Exact-match caching' },
      { n: '4.2', slug: 'semantic-cache', t: 'Caching by meaning' },
      { n: '4.3', slug: 'nearest-neighbor', t: 'Nearest-neighbor lookup' },
    ],
  },
  {
    n: '5', name: 'The Ledger', slug: 'ledger',
    blurb: 'Token accounting, cost, rate limits, and per-key budgets.',
    lessons: [
      { n: '5.1', slug: 'tokens-and-cost', t: 'Counting tokens and cost' },
      { n: '5.2', slug: 'rate-limiting', t: 'Rate limiting' },
      { n: '5.3', slug: 'budgets-and-fairness', t: 'Budgets and fairness' },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Course map · monkway</title>
  <meta name="description" content="The monkway course: 19 lessons across 6 units that teach how an LLM gateway works, from a plain proxy to routing, caching, and budgets." />
  <link rel="icon" type="image/svg+xml" href={base + "/logo.svg"} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="font-sans text-mt-text">

  <nav class="border-b border-mt-border bg-white/80 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-3xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href={base + "/"}><img src={base + "/logo-wordmark.svg"} alt="monkway" class="h-7" /></a>
      <div class="flex items-center gap-5 text-sm text-mt-muted">
        <a href={base + "/glossary"} class="hover:text-mt-text transition-colors">Glossary</a>
        <a href="https://github.com/monkfromearth/monkway" class="hover:text-mt-text transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <header class="max-w-3xl mx-auto px-6 pt-16 pb-10 text-center">
    <p class="text-xs font-mono uppercase tracking-widest text-mt-accent mb-3">The course</p>
    <h1 class="text-4xl font-bold tracking-tight mb-4">How an LLM gateway works</h1>
    <p class="text-lg text-mt-muted leading-relaxed max-w-xl mx-auto">
      Nineteen lessons across six units. We start at one door in front of one model, and end with a router that
      caches, falls back, and counts every token. The course teaches the ideas; you write the gateway.
    </p>
  </header>

  <main class="max-w-3xl mx-auto px-6 pb-16 space-y-5">
    {units.map((u) => (
      <section class="bg-mt-card border border-mt-border rounded-2xl p-6">
        <div class="flex items-baseline gap-3 mb-1">
          <span class="font-mono text-sm text-mt-accent font-semibold">Unit {u.n}</span>
          <h2 class="text-xl font-bold">{u.name}</h2>
        </div>
        <p class="text-sm text-mt-muted leading-relaxed mb-5">{u.blurb}</p>
        <ol class="divide-y divide-mt-border">
          {u.lessons.map((l) => (
            <li>
              <a href={`${base}/${u.slug}/${l.slug}`} class="flex items-center gap-4 py-3 group">
                <span class="shrink-0 w-12 font-mono text-xs text-mt-muted">{l.n}</span>
                <span class="font-medium group-hover:text-mt-accent transition-colors">{l.t}</span>
                <svg class="w-4 h-4 ml-auto text-mt-locked group-hover:text-mt-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}

    <a href={base + "/glossary"} class="block bg-mt-roseLight/50 border border-mt-border rounded-2xl p-6 hover:border-mt-rose transition-colors">
      <div class="flex items-center gap-3">
        <span class="font-mono text-sm text-mt-rose font-semibold">Glossary</span>
        <span class="text-sm text-mt-muted">Every term, plain English then precise.</span>
        <svg class="w-4 h-4 ml-auto text-mt-rose" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </div>
    </a>
  </main>

  <footer class="border-t border-mt-border py-8 text-center text-mt-muted text-sm">
    <p>
      Built by <a href="https://monkfrom.earth" class="text-mt-accent hover:underline">Sameer Khan (@monkfromearth)</a>
      &middot; part of the <a href="https://github.com/monkfromearth" class="text-mt-accent hover:underline">monk</a> family
      &middot; <a href="https://github.com/monkfromearth/monkway" class="text-mt-accent hover:underline">source</a>
    </p>
  </footer>

</body>
</html>

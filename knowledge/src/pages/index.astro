---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jobs = [
  { t: 'Greets every request at one door', d: 'A single API in front of many providers (the proxy).' },
  { t: 'Picks which path to send it down', d: 'Routing by cost, latency, or quality.' },
  { t: 'Reroutes when a door is closed', d: 'Retry with backoff, then fall over to another provider.' },
  { t: 'Recognizes travelers seen before', d: 'Exact and semantic caching, so a question is not paid for twice.' },
  { t: 'Keeps the ledger', d: 'Token, cost, and rate-limit tracking, with per-key budgets.' },
];

const units = [
  { n: '0', t: 'The gate', d: 'What a gateway is, and why one door in front of many models.', href: '/gate/what-a-gateway-is' },
  { n: '1', t: 'The proxy', d: 'Forwarding a request, and what "the same API" really means.', href: '/proxy/what-a-proxy-does' },
  { n: '2', t: 'When it fails', d: 'Retries, backoff and jitter, timeouts, and idempotency.', href: '/failure/ways-a-call-fails' },
  { n: '3', t: 'Choosing a path', d: 'Routing policy: cost vs latency vs quality, and fallback.', href: '/routing/routing-policy' },
  { n: '4', t: 'Remembering answers', d: 'Exact vs semantic caching, embeddings, nearest-neighbor lookup.', href: '/cache/exact-match-cache' },
  { n: '5', t: 'The ledger', d: 'Token accounting, cost, rate limits, and per-key budgets.', href: '/ledger/tokens-and-cost' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>monkway · Monk LLM Gateway</title>
  <meta name="description" content="monkway is an LLM gateway and router built from scratch: one API in front of many model providers, with retry, fallback, caching, and budgets. Built in the open, and taught." />
  <link rel="icon" type="image/svg+xml" href={base + "/logo.svg"} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="font-sans text-mt-text">

  <!-- nav -->
  <nav class="border-b border-mt-border bg-white/80 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
      <img src={base + "/logo-wordmark.svg"} alt="monkway" class="h-7" />
      <div class="flex items-center gap-5 text-sm text-mt-muted">
        <a href={base + "/learn"} class="hover:text-mt-text transition-colors">Course</a>
        <a href="https://github.com/monkfromearth/monkway/blob/main/docs/roadmap/index.md" class="hover:text-mt-text transition-colors">Roadmap</a>
        <a href="https://github.com/monkfromearth/monkway" class="hover:text-mt-text transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- hero -->
  <header class="max-w-3xl mx-auto px-6 pt-20 pb-16 text-center">
    <img src={base + "/logo.svg"} alt="" class="w-20 h-20 mx-auto mb-8" />
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-5">
      One API in front of <span class="text-mt-accent">every model</span>.
    </h1>
    <p class="text-lg text-mt-muted leading-relaxed max-w-xl mx-auto mb-8">
      monkway is an LLM gateway and router, built from scratch. It takes one request, routes it to the right
      provider, retries and falls back on failure, caches answers, and tracks cost and limits. Built in the
      open, and taught one piece at a time.
    </p>
    <div class="flex items-center justify-center gap-3">
      <a href={base + "/learn"} class="px-5 py-2.5 rounded-lg bg-mt-accent text-white font-semibold text-sm hover:opacity-90 transition-opacity">Start the course</a>
      <a href="https://github.com/monkfromearth/monkway" class="px-5 py-2.5 rounded-lg border border-mt-border bg-white font-semibold text-sm hover:border-mt-accent transition-colors">View on GitHub</a>
    </div>
  </header>

  <!-- metaphor -->
  <section class="max-w-3xl mx-auto px-6 py-14 border-t border-mt-border">
    <p class="text-xs font-mono uppercase tracking-widest text-mt-accent mb-3">The idea</p>
    <h2 class="text-2xl font-bold mb-4">Meet the gatekeeper</h2>
    <p class="text-mt-muted leading-relaxed mb-8 max-w-2xl">
      Picture a gatekeeper monk at the monastery gate. Every traveler arrives at one door. That one monk is
      the whole gateway, and every feature monkway has is just one more thing he does:
    </p>
    <ul class="grid sm:grid-cols-2 gap-3">
      {jobs.map((j) => (
        <li class="bg-mt-card border border-mt-border rounded-xl p-5">
          <p class="font-semibold mb-1">{j.t}</p>
          <p class="text-sm text-mt-muted leading-relaxed">{j.d}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- two stages -->
  <section class="max-w-3xl mx-auto px-6 py-14 border-t border-mt-border">
    <p class="text-xs font-mono uppercase tracking-widest text-mt-accent mb-3">How it's built</p>
    <h2 class="text-2xl font-bold mb-8">Two stages</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="bg-mt-card border border-mt-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-mono px-2 py-0.5 rounded bg-mt-accentLight text-mt-accent font-semibold">v1</span>
          <h3 class="font-bold">Proxy</h3>
        </div>
        <p class="text-sm text-mt-muted leading-relaxed">A single-provider proxy with retry, backoff, and
          structured logging of tokens, latency, and cost. Small in lines, the floor under it all.</p>
      </div>
      <div class="bg-mt-card border border-mt-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-mono px-2 py-0.5 rounded bg-mt-lavLight text-mt-lav font-semibold">v2</span>
          <h3 class="font-bold">Router</h3>
        </div>
        <p class="text-sm text-mt-muted leading-relaxed">Multi-provider routing, a semantic cache,
          cross-provider fallback, and per-key budgets and rate limits. Where it becomes a system.</p>
      </div>
    </div>
  </section>

  <!-- course outline -->
  <section id="course" class="max-w-3xl mx-auto px-6 py-14 border-t border-mt-border">
    <div class="flex items-center justify-between mb-2">
      <p class="text-xs font-mono uppercase tracking-widest text-mt-accent">The course</p>
      <span class="text-xs font-mono px-2 py-0.5 rounded bg-mt-greenLight text-mt-green font-semibold">19 lessons</span>
    </div>
    <h2 class="text-2xl font-bold mb-4">What you'll learn</h2>
    <p class="text-mt-muted leading-relaxed mb-8 max-w-2xl">
      An interactive course that teaches the concepts behind monkway, then leaves the implementation to you,
      which is where the understanding sticks. Six units, nineteen lessons, each with a demo you can drive.
      Start at the gate.
    </p>
    <ol class="space-y-3">
      {units.map((u) => (
        <li>
          <a href={base + u.href} class="flex items-start gap-4 bg-mt-card border border-mt-border rounded-xl p-5 hover:border-mt-accent transition-colors group">
            <span class="shrink-0 w-9 h-9 rounded-lg bg-mt-bg border border-mt-border flex items-center justify-center font-mono text-sm text-mt-muted">{u.n}</span>
            <div>
              <p class="font-semibold group-hover:text-mt-accent transition-colors">{u.t}</p>
              <p class="text-sm text-mt-muted leading-relaxed">{u.d}</p>
            </div>
          </a>
        </li>
      ))}
    </ol>
    <div class="mt-6 text-center">
      <a href={base + "/learn"} class="text-sm font-semibold text-mt-accent hover:underline">See the full course map &rarr;</a>
    </div>
  </section>

  <!-- footer -->
  <footer class="border-t border-mt-border py-8 mt-6 text-center text-mt-muted text-sm">
    <p>
      Built by <a href="https://monkfrom.earth" class="text-mt-accent hover:underline">Sameer Khan (@monkfromearth)</a>
      &middot; part of the <a href="https://github.com/monkfromearth" class="text-mt-accent hover:underline">monk</a> family
      &middot; <a href="https://github.com/monkfromearth/monkway" class="text-mt-accent hover:underline">source</a>
    </p>
  </footer>

</body>
</html>

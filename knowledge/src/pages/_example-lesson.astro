---
/**
 * REFERENCE LESSON — copy this as the starting point for a new lesson page.
 * Path convention: src/pages/<unit>/<slug>.astro  (e.g. src/pages/foundations/derivatives.astro)
 * Follow AUTHORING.md for voice, structure, and the animation policy.
 */
import '../styles/global.css';
import LessonLayout from '../layouts/LessonLayout.astro';
import LessonHeader from '../components/LessonHeader.astro';
import LessonNav from '../components/LessonNav.astro';
import InsightBox from '../components/InsightBox.astro';
import TagBadge from '../components/TagBadge.astro';
import ExampleDragDemo from '../components/demos/_ExampleDragDemo.astro';
---

<LessonLayout title="The Concept's Title" lessonNumber="0.1" section="Unit Name">

    <LessonHeader lessonNumber="0.1" title="The Concept's Title" description="One or two sentences: what this lesson makes click, framed in plain language.">
        <TagBadge variant="concepts">concepts</TagBadge>
        <TagBadge variant="default">9 min read</TagBadge>
    </LessonHeader>

    <!-- SECTION 1: hook with an analogy, then the concept, then a worked example, then an insight. -->
    <section class="mb-14">
        <h2 class="text-xl font-bold mb-4">Lead with a concrete image.</h2>
        <p class="text-mt-muted leading-relaxed mb-4">
            Open with an everyday analogy a smart friend would get, then name the precise term once.
        </p>

        <!-- The single meaningful demo for this lesson. Metaphor-first, direct manipulation. -->
        <ExampleDragDemo />

        <InsightBox>
            <p class="text-sm">An <strong>InsightBox</strong> names the one thing to remember from this section.</p>
        </InsightBox>
    </section>

    <!-- SECTION 2: a worked example readers can follow by hand. -->
    <section class="mb-14">
        <h2 class="text-xl font-bold mb-4">Show it with real numbers.</h2>
        <div class="bg-white border border-mt-border rounded-xl p-5 mb-4 font-mono text-sm">
            a = 3 &nbsp;&rarr;&nbsp; a &times; a = 9
        </div>
        <p class="text-mt-muted leading-relaxed">Keep the demo's starting values matching this worked example.</p>
    </section>

    <!-- Key takeaways: exactly three, numbered. -->
    <section class="mb-14">
        <h2 class="text-xl font-bold mb-4">Key takeaways</h2>
        <div class="space-y-3">
            <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-full bg-mt-accentLight flex items-center justify-center flex-shrink-0 mt-0.5"><span class="text-mt-accent font-bold text-xs">1</span></div><p class="text-sm">First takeaway, in one plain sentence.</p></div>
            <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-full bg-mt-accentLight flex items-center justify-center flex-shrink-0 mt-0.5"><span class="text-mt-accent font-bold text-xs">2</span></div><p class="text-sm">Second takeaway.</p></div>
            <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-full bg-mt-accentLight flex items-center justify-center flex-shrink-0 mt-0.5"><span class="text-mt-accent font-bold text-xs">3</span></div><p class="text-sm">Third takeaway, ideally setting up the next lesson.</p></div>
        </div>
    </section>

    <LessonNav
        prevHref="/unit/prev-slug" prevLabel="Prev: Previous Lesson"
        nextHref="/unit/next-slug" nextLabel="Next: Next Lesson"
    />

</LessonLayout>
